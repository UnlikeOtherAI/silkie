# Copy this file to .env and fill in the values.
# .env is gitignored; never commit secrets.

# -- Public hosts -------------------------------------------------------------
UOA_DOMAIN=selkie.live
ADMIN_HOST=admin.selkie.live
API_HOST=api.selkie.live
RELAY_HOST=relay.selkie.live

# -- UOA (UnlikeOtherAuthenticator) ------------------------------------------
UOA_BASE_URL=https://authentication.unlikeotherai.com
UOA_SHARED_SECRET=<from UOA dashboard; HS256 signing key for config JWT and token verification>
UOA_AUDIENCE=auth.unlikeotherai.com
UOA_CONFIG_URL=https://admin.selkie.live/auth/uoa-config
UOA_REDIRECT_URL=https://admin.selkie.live/auth/callback

# Set automatically on first login; do not set manually.
# UOA_OWNER_SUB=<first user's UOA sub, persisted to DB after first login>

# -- PostgreSQL ---------------------------------------------------------------
# Shared PostgreSQL is the approved prototype posture. The VM reaches it through Cloud SQL Auth Proxy.
CLOUDSQL_INSTANCE_CONNECTION_NAME=gen-lang-client-0561071620:europe-west1:uoa-auth-db
DATABASE_URL=postgres://selkie:<password>@127.0.0.1:5432/selkie?sslmode=disable

# -- Redis --------------------------------------------------------------------
# Shared Redis is hosted on the Belgium edge VM for the prototype.
REDIS_PASSWORD=<redis-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@127.0.0.1:6379/0

# -- Internal session signing -------------------------------------------------
# Separate from UOA_SHARED_SECRET. Generate: openssl rand -base64 64
INTERNAL_SESSION_SECRET=<hs256-key-for-internal-jwts>

# -- coturn (TURN relay) ------------------------------------------------------
TURN_HOST=${RELAY_HOST}
TURN_EXTERNAL_IP=<relay public IPv4>
TURN_BIND_IP=<vm primary internal IPv4>
TURN_PORT=3478
# HMAC secret shared with coturn (use-auth-secret mode). Generate: openssl rand -base64 32
COTURN_SECRET=<coturn-static-auth-secret>
COTURN_REALM=selkie
# Optional coturn allocation lifecycle tracking via Redis statsdb.
COTURN_REDIS_STATSDB=redis://:${REDIS_PASSWORD}@127.0.0.1:6379/1
COTURN_CLI_ADDR=127.0.0.1:5766
COTURN_CLI_PASSWORD=<coturn-cli-password>

# -- WireGuard overlay --------------------------------------------------------
WG_OVERLAY_CIDR=10.100.0.0/16
WG_INTERFACE_NAME=wg0
WG_PRIVATE_KEY=<server wg private key; wg genkey>
WG_SERVER_PUBLIC_KEY=<server wg public key; echo "$WG_PRIVATE_KEY" | wg pubkey>
WG_SERVER_ENDPOINT=${RELAY_HOST}
WG_SERVER_PORT=51820

# -- Server -------------------------------------------------------------------
SERVER_PORT=8080
LOG_LEVEL=info
# Set to true to enable /auth/dev-login bypass (local development only).
# DEV_MODE=true

# -- Policy (optional) --------------------------------------------------------
# OPA endpoint for policy evaluation. Leave empty for allow-all mode.
# OPA_ENDPOINT=http://localhost:8181

# -- Observability (optional) -------------------------------------------------
# OTLP gRPC endpoint. Leave empty to disable telemetry.
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
